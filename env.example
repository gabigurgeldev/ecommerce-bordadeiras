# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
# Self-hosted: https://supabase.bordadeiras.cloud — URI no Studio → Database
DATABASE_URL="postgresql://postgres:<senha_forte_do_banco>@supabase.bordadeiras.cloud:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL=https://supabase.bordadeiras.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage — crie buckets públicos no Studio (product-images, banners)
SUPABASE_BUCKET_PRODUCT_IMAGES=product-images
SUPABASE_BUCKET_BANNERS=banners

# ─── Auth (Supabase Auth + Prisma User por e-mail) ───────────────────────────
# Redirect URLs no Supabase: Site URL = NEXT_PUBLIC_APP_URL, allow /auth/callback
ADMIN_EMAIL=<email_admin_real>
ADMIN_PASSWORD=<gere_senha_forte_12_chars_min>

# ─── Seed overrides (optional) ───────────────────────────────────────────────
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# ─── Redis / rate limit (Upstash or local) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=redis://localhost:6379

# ─── Email (SMTP / Nodemailer) ───────────────────────────────────────────────
# Também configurável em Admin → Configurações → SMTP (salvo no Postgres como smtp.*)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bordadeiras <noreply@bordadeiras.com.br>"

# ─── Mercado Pago ───────────────────────────────────────────────────────────
# Credenciais configuradas no painel Admin → Configurações (salvas no Postgres).

# ─── Melhor Envio (frete) ────────────────────────────────────────────────────
# Access Token no Admin → Configurações → Frete e Envio (salvo no Postgres).
# Gere o token no painel ME (Permissões de Acesso, scope shipping-calculate).

# ─── WhatsApp service (Baileys) ──────────────────────────────────────────────
WHATSAPP_SERVICE_URL=http://localhost:4001
WHATSAPP_SERVICE_SECRET=<gere_com_openssl_rand_base64_32>

# ─── MinIO local (docker-compose.yml) ─────────────────────────────────────────
S3_ACCESS_KEY=<gere_usuario_minio_local>
S3_SECRET_KEY=<gere_senha_minio_local>
