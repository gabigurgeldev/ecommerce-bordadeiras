# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (MySQL 8) ──────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/bordadeiras"

# ─── Auth (NextAuth v5) ─────────────────────────────────────────────────────
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@bordadeiras.com.br
ADMIN_PASSWORD=Admin@123456

# ─── Seed overrides (optional) ───────────────────────────────────────────────
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# ─── Redis / rate limit (Upstash or local) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=redis://localhost:6379

# ─── Email (SMTP / Nodemailer) ───────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bordadeiras <noreply@bordadeiras.com.br>"

# ─── Storage (S3-compatible) ───────────────────────────────────────────────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=bordadeiras-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ─── Mercado Pago (payments agent) ─────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# ─── WhatsApp service (Baileys agent) ────────────────────────────────────────
WHATSAPP_SERVICE_URL=http://localhost:3001
WHATSAPP_SERVICE_SECRET=
