# =============================================================================
# Ecommerce Bordadeiras — variáveis de PRODUÇÃO (exemplo)
# =============================================================================
# Copie para .env na VPS: cp env.production.example .env
# NÃO commite o .env real. Substitua SEUDOMINIO.COM.BR pelo seu domínio base.
#
# Exemplo de domínios (base: bordadeiras.com.br):
#   loja.bordadeiras.com.br      → Next.js (loja + /api/* webhooks)
#   storage.bordadeiras.com.br   → MinIO API (S3)
#   console.storage...           → MinIO console (opcional, restrinja IP)
#   whatsapp.bordadeiras.com.br  → serviço Baileys (opcional; prefira só rede interna)
# =============================================================================

# ─── Metadados do deploy (opcional, para scripts) ───────────────────────────
DOMAIN=bordadeiras.com.br
LOJA_HOST=loja.bordadeiras.com.br
STORAGE_HOST=storage.bordadeiras.com.br

# =============================================================================
# SEÇÃO A — URLs públicas (EasyPanel / reverse proxy / DNS)
# Use estas na app Next.js e em painéis externos (Mercado Pago, Google).
# =============================================================================

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://loja.bordadeiras.com.br
NEXT_PUBLIC_SITE_URL=https://loja.bordadeiras.com.br
# Auth: Supabase (Site URL = NEXT_PUBLIC_APP_URL; redirect /auth/callback)

# Mercado Pago — webhook aponta para a MESMA loja (não precisa subdomínio api.*)
# URL no painel MP: https://loja.bordadeiras.com.br/api/webhooks/mercadopago

# Imagens: Supabase Storage (URLs públicas em NEXT_PUBLIC_SUPABASE_URL/storage/v1/object/public/...)

# Google OAuth (quando habilitado no código) — redirect:
# https://loja.bordadeiras.com.br/api/auth/callback/google

# =============================================================================
# SEÇÃO B — Rede Docker interna (docker-compose.prod.yml)
# Hostnames = nomes dos services no compose. NÃO use localhost na app em container.
# =============================================================================

# Supabase self-hosted — https://supabase.bordadeiras.cloud (fora do compose)
# URI: Studio → Database → Connection string. Migrations: porta direct 5432 (sem pooler).
DATABASE_URL=postgresql://postgres:ALTERE_SENHA@supabase.bordadeiras.cloud:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://supabase.bordadeiras.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_PRODUCT_IMAGES=product-images
SUPABASE_BUCKET_BANNERS=banners

# Redis — service: redis
REDIS_URL=redis://redis:6379

# WhatsApp Baileys — service: whatsapp-service (destinatários no Admin → WhatsApp)
WHATSAPP_SERVICE_URL=http://whatsapp-service:4001
WHATSAPP_SERVICE_SECRET=ALTERE_SECRET_COMPARTILHADO_APP_E_WHATSAPP

# =============================================================================
# SEÇÃO C — Somente app Next.js (EasyPanel UI ou container app)
# =============================================================================

ADMIN_EMAIL=admin@bordadeiras.com.br
ADMIN_PASSWORD=ALTERE_ANTES_DO_SEED

# Mercado Pago: configure em Admin → Configurações (salvo no Postgres, não use env)

# Rate limit — use Redis local OU Upstash (nuvem)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# E-mail — SMTP externo (recomendado) ou Postal self-hosted
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@bordadeiras.com.br
SMTP_PASS=...
SMTP_FROM="Bordadeiras <noreply@bordadeiras.com.br>"

# Google (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# SEÇÃO D — Somente Docker Compose na VPS (infra)
# Banco (Supabase) não roda no compose — monte DATABASE_URL e keys Supabase na app.
# =============================================================================

# Supabase Storage: buckets product-images e banners (públicos para leitura)

# Porta do serviço WhatsApp (padrão 4001)
PORT=4001

# =============================================================================
# NOTAS
# =============================================================================
# - WHATSAPP_SERVICE_URL no env.example local diz 3001; o container usa 4001.
# - EasyPanel: cole Seção A + C na app; Seção B nas URLs internas da app.
# - Se a app NÃO estiver no mesmo compose, conecte-a à rede: docker network connect bordadeiras_internal NOME_CONTAINER_APP
