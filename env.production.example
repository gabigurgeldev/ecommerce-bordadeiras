# =============================================================================
# Ecommerce Bordadeiras â€” variĂ¡veis de PRODUĂ‡ĂƒO (exemplo)
# =============================================================================
# Copie para .env na VPS: cp env.production.example .env
# NĂƒO commite o .env real. Substitua SEUDOMINIO.COM.BR pelo seu domĂ­nio base.
#
# Exemplo de domĂ­nios (base: bordadeiras.com.br):
#   loja.bordadeiras.com.br      â†’ Next.js (loja + /api/* webhooks)
#   storage.bordadeiras.com.br   â†’ MinIO API (S3)
#   console.storage...           â†’ MinIO console (opcional, restrinja IP)
#   whatsapp.bordadeiras.com.br  â†’ serviĂ§o Baileys (opcional; prefira sĂ³ rede interna)
# =============================================================================

# â”€â”€â”€ Metadados do deploy (opcional, para scripts) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
DOMAIN=bordadeiras.com.br
LOJA_HOST=loja.bordadeiras.com.br
STORAGE_HOST=storage.bordadeiras.com.br

# =============================================================================
# SEĂ‡ĂƒO A â€” URLs pĂºblicas (EasyPanel / reverse proxy / DNS)
# Use estas na app Next.js e em painĂ©is externos (Mercado Pago, Google).
# =============================================================================

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://loja.bordadeiras.com.br
NEXT_PUBLIC_SITE_URL=https://loja.bordadeiras.com.br
AUTH_URL=https://loja.bordadeiras.com.br

# Mercado Pago â€” webhook aponta para a MESMA loja (nĂ£o precisa subdomĂ­nio api.*)
# URL no painel MP: https://loja.bordadeiras.com.br/api/webhooks/mercadopago

# MinIO â€” URL pĂºblica para links de imagens no navegador
S3_PUBLIC_URL=https://storage.bordadeiras.com.br

# Google OAuth (quando habilitado no cĂ³digo) â€” redirect:
# https://loja.bordadeiras.com.br/api/auth/callback/google

# =============================================================================
# SEĂ‡ĂƒO B â€” Rede Docker interna (docker-compose.prod.yml)
# Hostnames = nomes dos services no compose. NĂƒO use localhost na app em container.
# =============================================================================

# MySQL â€” service: mysql
MYSQL_ROOT_PASSWORD=ALTERE_ROOT_FORTE
MYSQL_DATABASE=bordadeiras
MYSQL_USER=bordadeiras
MYSQL_PASSWORD=ALTERE_SENHA_APP
DATABASE_URL=mysql://bordadeiras:ALTERE_SENHA_APP@mysql:3306/bordadeiras

# Redis â€” service: redis
REDIS_URL=redis://redis:6379

# MinIO â€” service: minio (API interna; console em :9001 se expuser)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=bordadeiras-uploads
S3_ACCESS_KEY=ALTERE_MINIO_USER
S3_SECRET_KEY=ALTERE_MINIO_SECRET_FORTE

# WhatsApp Baileys â€” service: whatsapp-service (destinatĂ¡rios no Admin â†’ WhatsApp)
WHATSAPP_SERVICE_URL=http://whatsapp-service:4001
WHATSAPP_SERVICE_SECRET=ALTERE_SECRET_COMPARTILHADO_APP_E_WHATSAPP

# =============================================================================
# SEĂ‡ĂƒO C â€” Somente app Next.js (EasyPanel UI ou container app)
# =============================================================================

AUTH_SECRET=GERE_COM_openssl_rand_-base64_32
ADMIN_EMAIL=admin@bordadeiras.com.br
ADMIN_PASSWORD=ALTERE_ANTES_DO_SEED

# Mercado Pago: configure em Admin â†’ ConfiguraĂ§Ăµes (salvo no MySQL, nĂ£o use env)

# Rate limit â€” use Redis local OU Upstash (nuvem)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# E-mail â€” SMTP externo (recomendado) ou Postal self-hosted
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@bordadeiras.com.br
SMTP_PASS=...
SMTP_FROM="Bordadeiras <noreply@bordadeiras.com.br>"

# Google (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# SEĂ‡ĂƒO D â€” Somente Docker Compose na VPS (infra)
# A app no EasyPanel pode ignorar MYSQL_* se DATABASE_URL jĂ¡ estiver montada.
# =============================================================================

# MinIO no compose usa S3_ACCESS_KEY / S3_SECRET_KEY como MINIO_ROOT_USER/PASSWORD
# Crie o bucket apĂ³s subir: mc alias / console â†’ bucket S3_BUCKET

# Porta do serviĂ§o WhatsApp (padrĂ£o 4001)
PORT=4001

# =============================================================================
# NOTAS
# =============================================================================
# - env.example usa S3_ACCESS_KEY_ID; o cĂ³digo (storage.ts) lĂª S3_ACCESS_KEY.
# - WHATSAPP_SERVICE_URL no env.example local diz 3001; o container usa 4001.
# - EasyPanel: cole SeĂ§Ă£o A + C na app; SeĂ§Ă£o B nas URLs internas da app.
# - Se a app NĂƒO estiver no mesmo compose, conecte-a Ă  rede: docker network connect bordadeiras_internal NOME_CONTAINER_APP
