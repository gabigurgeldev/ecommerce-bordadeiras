# Copie para .env na raiz do repo (docker compose) ou exporte ao rodar localmente.
# O serviço usa o mesmo schema Prisma da app (raiz prisma/schema.prisma).

PORT=4001
WHATSAPP_SERVICE_SECRET=altere-secret-compartilhado-com-a-app

# PostgreSQL — mesma DATABASE_URL da app Next.js
DATABASE_URL=postgresql://postgres:senha@localhost:5432/postgres
# DATABASE_URL=postgresql://postgres:senha@supabase.bordadeiras.cloud:5432/postgres
