# Copie para .env.local (dev). Produção: docs/EASYPANEL_ENV.md
# Dados + Auth + Storage: apenas Supabase (sem Prisma, sem DATABASE_URL)

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://supabase.bordadeiras.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_BUCKET_PRODUCT_IMAGES=product-images
SUPABASE_BUCKET_BANNERS=banners

REDIS_URL=redis://localhost:6379

WHATSAPP_SERVICE_URL=http://localhost:4001
WHATSAPP_SERVICE_SECRET=altere-secret-compartilhado

ADMIN_EMAIL=admin@bordadeiras.com.br
ADMIN_PASSWORD=altere-antes-do-seed

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_INSECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bordadeiras <noreply@example.com>"
