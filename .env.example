# Dev: copie para .env.local (Next.js) E espelhe DATABASE_URL + Supabase em .env (Prisma CLI).
# Produção: docs/EASYPANEL_ENV.md (app vs whatsapp-service).
# NÃO commite arquivos .env com senhas reais. Veja env.production.example e docs/EASYPANEL_RECOVERY.md

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Supabase Auth (SSR) — https://supabase.bordadeiras.cloud
# No painel Auth: Site URL = NEXT_PUBLIC_APP_URL; redirect allow: /auth/callback
# Connection string: Studio → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:SENHA@supabase.bordadeiras.cloud:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://supabase.bordadeiras.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage (buckets públicos no Studio → Storage)
SUPABASE_BUCKET_PRODUCT_IMAGES=product-images
SUPABASE_BUCKET_BANNERS=banners

REDIS_URL=redis://localhost:6379

WHATSAPP_SERVICE_URL=http://localhost:4001
WHATSAPP_SERVICE_SECRET=altere-secret-compartilhado

ADMIN_EMAIL=admin@bordadeiras.com.br
ADMIN_PASSWORD=altere-antes-do-seed
RUN_DB_SEED=true

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bordadeiras <noreply@example.com>"
