# Copie para .env.local (dev) ou configure no EasyPanel (produção).
# NÃO commite arquivos .env com senhas reais. Veja env.production.example e docs/EASYPANEL_RECOVERY.md

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_SECRET=altere-com-openssl-rand-base64-32

DATABASE_URL=mysql://bordadeiras:senha@localhost:3306/bordadeiras
REDIS_URL=redis://localhost:6379

S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_BUCKET=bordadeiras-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

WHATSAPP_SERVICE_URL=http://localhost:4001
WHATSAPP_SERVICE_SECRET=altere-secret-compartilhado

ADMIN_EMAIL=admin@bordadeiras.com.br
ADMIN_PASSWORD=altere-antes-do-seed
RUN_DB_SEED=true

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bordadeiras <noreply@example.com>"
